# LLM Configuration
# Default: Use local Ollama (no API key needed)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# Optional: Use Anthropic API instead (requires API key)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# MODEL_NAME=claude-sonnet-4-20250514

# Optional: Use OpenAI API instead (requires API key)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
# MODEL_NAME=gpt-4
